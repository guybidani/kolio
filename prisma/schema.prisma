generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  CEO
  MANAGER
  REP
  VIEWER
}

enum CallDirection {
  INBOUND
  OUTBOUND
  UNKNOWN
}

enum CallStatus {
  UPLOADED
  TRANSCRIBING
  TRANSCRIBED
  ANALYZING
  COMPLETE
  FAILED
  TOO_SHORT
}

enum CallSource {
  PBX_WEBHOOK
  MANUAL_UPLOAD
  MOBILE_APP
  GOOGLE_DRIVE
  EMAIL_IMPORT
  FTP_IMPORT
  API_IMPORT
}

enum BadgeType {
  REP_OF_THE_WEEK
  PERFECT_SCORE
  STREAK_7
  STREAK_30
  OBJECTION_MASTER
  DISCOVERY_PRO
  CLOSER
  MOST_IMPROVED
  FIRST_CALL
  HUNDRED_CALLS
}

enum StreakType {
  DAILY_CALLS
  HIGH_SCORE
  IMPROVEMENT
}

enum NotificationType {
  LOW_SCORE
  HIGH_SCORE
  BADGE_EARNED
  WEEKLY_REPORT
  COACHING_TIP
  STREAK_AT_RISK
  TEAM_MILESTONE
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  plan             Plan     @default(TRIAL)
  planSeats        Int      @default(3)
  trialEndsAt      DateTime?
  planExpiresAt    DateTime?
  settings         Json     @default("{}")
  webhookSecret    String   @default(uuid())
  importConfig     Json     @default("{}")
  apiKey           String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  reps             Rep[]
  calls            Call[]
  playbooks        Playbook[]
  weeklyReports    WeeklyReport[]
  pbxIntegrations  PbxIntegration[]
  badges           Badge[]
  streaks          Streak[]
}

model User {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(VIEWER)
  isAdmin      Boolean  @default(false)
  isActive         Boolean  @default(true)
  emailVerified    Boolean  @default(false)
  verifyToken      String?
  verifyTokenExp   DateTime?
  avatarUrl        String?
  resetToken       String?
  resetTokenExp    DateTime?
  emailNotifications Boolean @default(true)
  emailDigest      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  managedReps      Rep[]    @relation("ManagedReps")
  repProfile       Rep?     @relation("RepUser")
  notifications    Notification[]
  practiceSessions PracticeSession[]

  @@unique([orgId, email])
  @@index([orgId])
}

model Rep {
  id         String   @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  extension  String?
  avatarUrl  String?
  isActive   Boolean  @default(true)
  managerId  String?
  manager    User?    @relation("ManagedReps", fields: [managerId], references: [id])
  teamId     String?
  userId     String?  @unique
  user       User?    @relation("RepUser", fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  calls      Call[]
  badges     Badge[]
  streaks    Streak[]

  @@index([orgId])
  @@index([orgId, extension])
  @@index([managerId])
}

model Call {
  id             String        @id @default(cuid())
  orgId          String
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  repId          String?
  rep            Rep?          @relation(fields: [repId], references: [id])

  audioUrl       String
  audioSize      Int?
  duration       Int           @default(0)
  direction      CallDirection @default(UNKNOWN)
  callerNumber   String?
  calledNumber   String?

  status         CallStatus    @default(UPLOADED)
  errorMessage   String?

  transcript     Json?
  transcriptText String?
  language       String?

  overallScore   Float?
  scores         Json?
  summary        String?
  prospectName   String?
  prospectBusiness String?
  keyMoments     Json?
  objections     Json?
  coachingTips   Json?
  retentionPoints Json?
  improvementPoints Json?
  nextCallPrep   Json?
  spinAnalysis   Json?
  internalInsights Json?
  talkRatio      Json?

  // Advanced analytics fields
  competitorMentions  Json?
  pricingDiscussion   Json?
  sentimentTrajectory Json?
  fillerWordCount     Int?
  questionCount       Int?
  longestMonologue    Int?
  silenceGaps         Int?
  talkRatioRep        Float?
  talkRatioCustomer   Float?
  energyScore         Float?
  nextStepsScore      Float?

  // Manager comments (JSON array of comment objects)
  comments            Json?

  // Enhanced analysis fields
  callType            String?
  pricingDetails      Json?
  buyingSignals       Json?
  nextStepsClarity    Json?
  benchmarkComparison Json?

  source         CallSource    @default(MANUAL_UPLOAD)
  externalId     String?
  pbxType        String?
  recordedAt     DateTime      @default(now())
  processedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([orgId, repId])
  @@index([orgId, recordedAt])
  @@index([orgId, status])
  @@index([status])
  @@index([orgId, externalId])
}

model Playbook {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  stages      Json     @default("[]")
  objectionBank Json   @default("[]")
  keywords    Json     @default("{}")
  techniques  Json     @default("[]")
  scripts     Json     @default("[]")
  scoringWeights Json  @default("{}")
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
}

model WeeklyReport {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  weekEnd     DateTime
  totalCalls  Int      @default(0)
  avgScore    Float?
  topRep      String?
  highlights  Json     @default("[]")
  data        Json     @default("{}")
  emailSentAt DateTime?
  createdAt   DateTime @default(now())

  @@unique([orgId, weekStart])
  @@index([orgId, weekStart])
}

model PbxIntegration {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pbxType     String
  config      Json     @default("{}")
  extensionMap Json    @default("{}")
  isActive    Boolean  @default(true)
  webhookUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
}

model Badge {
  id          String    @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  repId       String
  rep         Rep       @relation(fields: [repId], references: [id], onDelete: Cascade)
  type        BadgeType
  name        String
  description String
  earnedAt    DateTime  @default(now())
  weekOf      DateTime?

  @@index([orgId, repId])
  @@index([orgId, weekOf])
}

model Streak {
  id           String       @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  repId        String
  rep          Rep          @relation(fields: [repId], references: [id], onDelete: Cascade)
  type         StreakType
  currentCount Int          @default(0)
  bestCount    Int          @default(0)
  lastDate     DateTime

  @@unique([orgId, repId, type])
  @@index([orgId])
}

model Notification {
  id        String           @id @default(cuid())
  orgId     String
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([orgId, createdAt])
}

model PracticeSession {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario     String   // discovery, demo, closing, objection-handling
  difficulty   String   // easy, medium, hard
  messages     Json     @default("[]")
  isComplete   Boolean  @default(false)
  evaluation   Json?
  overallScore Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId, userId])
}
